{"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"NodeKit ships with four primitive port types (","type":"text"},{"type":"reference","identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType\/bool","isActive":true},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType\/int","isActive":true},{"type":"text","text":", "},{"isActive":true,"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType\/double","type":"reference"},{"type":"text","text":", "},{"isActive":true,"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType\/string","type":"reference"},{"type":"text","text":") and their"},{"type":"text","text":" "},{"type":"text","text":"matching inline editors. Anything richer plugs in through two registries:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortTypeRegistry"},{"type":"text","text":" — the catalog of known "},{"type":"reference","isActive":true,"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType"},{"type":"text","text":"s, looked up by"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType\/id","isActive":true},{"text":". Drives the editor’s display hints (port colour, type","type":"text"},{"text":" ","type":"text"},{"text":"name).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortEditorRegistry"},{"text":" — the per-type default value plus a SwiftUI","type":"text"},{"type":"text","text":" "},{"type":"text","text":"editor for inline values."}]}]}],"type":"orderedList"},{"inlineContent":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/NodeTemplate\/Port","isActive":true,"type":"reference"},{"text":" references its type by ","type":"text"},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/NodeTemplate\/Port\/typeIdentifier","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"type":"text","text":"(a "},{"code":"String","type":"codeVoice"},{"type":"text","text":"), not by embedding the "},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType","isActive":true,"type":"reference"},{"text":" value. The editor resolves","type":"text"},{"text":" ","type":"text"},{"text":"the identifier through ","type":"text"},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortTypeRegistry","isActive":true,"type":"reference"},{"text":" at render time. This lets","type":"text"},{"text":" ","type":"text"},{"text":"multiple templates share one registered type, and lets a port wire up","type":"text"},{"text":" ","type":"text"},{"text":"correctly even when its type isn’t (yet, or no longer) registered — port","type":"text"},{"text":" ","type":"text"},{"text":"compatibility compares identifier strings directly on the drag\/hover hot","type":"text"},{"text":" ","type":"text"},{"text":"path, with no registry round-trip.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Keep your ","type":"text"},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType\/id","isActive":true,"type":"reference"},{"text":" strings stable across releases — they’re","type":"text"},{"text":" ","type":"text"},{"text":"persisted on every port that references them.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Define-the-type","text":"Define the type","type":"heading"},{"syntax":"swift","type":"codeListing","code":["import NodeKit","","extension PortType {","    static let color = PortType(","        id: \"myapp.color\",","        localizedDisplayName: \"Color\",","        color: .init(red: 0.95, green: 0.40, blue: 0.55)","    )","}","","let portTypes = PortTypeRegistry()","portTypes.register(.color)"]},{"inlineContent":[{"text":"The optional ","type":"text"},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/ColorComponents","isActive":true,"type":"reference"},{"text":" is a display hint — it colours the port","type":"text"},{"text":" ","type":"text"},{"text":"circle in the editor.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Reference-the-type-from-a-template","text":"Reference the type from a template","type":"heading"},{"inlineContent":[{"text":"Ports take a ","type":"text"},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/NodeTemplate\/Port\/typeIdentifier","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let template = NodeTemplate(","    kind: .init(id: UUID(), localizedDisplayName: \"Tinter\"),","    inputs: [","        .init(id: UUID(), kind: .input,","              typeIdentifier: PortType.color.id,","              localizedDisplayName: \"Tint\")","    ],","    outputs: []",")"]},{"inlineContent":[{"text":"For convenience there’s an overload that takes a ","type":"text"},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType","isActive":true,"type":"reference"},{"text":" value","type":"text"},{"text":" ","type":"text"},{"text":"directly — same effect, fewer keystrokes when the type is in scope:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":[".init(id: UUID(), kind: .input, type: .color, localizedDisplayName: \"Tint\")"]},{"level":2,"anchor":"Register-an-inline-editor","text":"Register an inline editor","type":"heading"},{"inlineContent":[{"text":"Inline editors run when the user adds a literal value to an input port (the","type":"text"},{"text":" ","type":"text"},{"code":"+","type":"codeVoice"},{"text":" button next to a port label). They get a strong-typed ","type":"text"},{"code":"Binding<V>","type":"codeVoice"},{"text":"; the","type":"text"},{"text":" ","type":"text"},{"text":"registry handles encoding to and from ","type":"text"},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortValue\/custom(typeIdentifier:data:)","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"through ","type":"text"},{"code":"JSONEncoder","type":"codeVoice"},{"text":"\/","type":"text"},{"code":"JSONDecoder","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct ColorValue: Codable, Sendable, Equatable {","    var red: Double, green: Double, blue: Double","}","","let editors = PortEditorRegistry()","editors.register(","    for: PortType.color.id,","    defaultValue: ColorValue(red: 1, green: 1, blue: 1)",") { binding in","    ColorPicker(","        \"\",","        selection: Binding(","            get: { Color(red: binding.wrappedValue.red,","                         green: binding.wrappedValue.green,","                         blue:  binding.wrappedValue.blue) },","            set: { _ in \/* decompose Color back into RGB *\/ }","        )","    )","    .labelsHidden()","}"]},{"inlineContent":[{"text":"The same ","type":"text"},{"type":"codeVoice","code":"defaultValue"},{"text":" is used as the fallback when stored data fails to","type":"text"},{"text":" ","type":"text"},{"text":"decode — handy if you evolve the schema across releases.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Hand-the-registries-to-the-editor","text":"Hand the registries to the editor","type":"heading"},{"inlineContent":[{"text":"Pass both registries to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/GraphEditor","type":"reference"},{"text":" so it can resolve types for","type":"text"},{"text":" ","type":"text"},{"text":"display and surface your inline editor for the ","type":"text"},{"type":"codeVoice","code":"+"},{"text":" button.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["GraphEditor(",