{"schemaVersion":{"minor":3,"major":0,"patch":0},"seeAlsoSections":[{"title":"Extending NodeKit","identifiers":["doc:\/\/NodeKit\/documentation\/NodeKit\/GraphStore"],"generated":true,"anchor":"Extending-NodeKit"}],"abstract":[{"type":"text","text":"Teach NodeKit about a new value type and how the user should edit it inline."}],"variants":[{"paths":["\/documentation\/nodekit\/customporttypes"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"article","metadata":{"modules":[{"name":"NodeKit"}],"roleHeading":"Article","title":"Adding custom port types","role":"article"},"hierarchy":{"paths":[["doc:\/\/NodeKit\/documentation\/NodeKit"]]},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"NodeKit ships with four primitive port types (","type":"text"},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType\/bool","isActive":true,"type":"reference"},{"type":"text","text":","},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType\/int","isActive":true},{"text":", ","type":"text"},{"type":"reference","identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType\/double","isActive":true},{"text":", ","type":"text"},{"type":"reference","identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType\/string","isActive":true},{"type":"text","text":") and their"},{"type":"text","text":" "},{"text":"matching inline editors. Anything richer plugs in through two registries:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"isActive":true,"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortTypeRegistry","type":"reference"},{"text":" — the catalog of known ","type":"text"},{"isActive":true,"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType","type":"reference"},{"type":"text","text":"s, looked up by"},{"type":"text","text":" "},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType\/id","type":"reference","isActive":true},{"type":"text","text":". Drives the editor’s display hints (port colour, type"},{"type":"text","text":" "},{"type":"text","text":"name)."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortEditorRegistry","isActive":true},{"type":"text","text":" — the per-type default value plus a SwiftUI"},{"type":"text","text":" "},{"type":"text","text":"editor for inline values."}]}]}],"type":"orderedList"},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/NodeTemplate\/Port","isActive":true,"type":"reference"},{"text":" references its type by ","type":"text"},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/NodeTemplate\/Port\/typeIdentifier","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"(a ","type":"text"},{"code":"String","type":"codeVoice"},{"text":"), not by embedding the ","type":"text"},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType","isActive":true,"type":"reference"},{"text":" value. The editor resolves","type":"text"},{"text":" ","type":"text"},{"text":"the identifier through ","type":"text"},{"identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortTypeRegistry","isActive":true,"type":"reference"},{"text":" at render time. This lets","type":"text"},{"text":" ","type":"text"},{"text":"multiple templates share one registered type, and lets a port wire up","type":"text"},{"text":" ","type":"text"},{"text":"correctly even when its type isn’t (yet, or no longer) registered — port","type":"text"},{"text":" ","type":"text"},{"text":"compatibility compares identifier strings directly on the drag\/hover hot","type":"text"},{"text":" ","type":"text"},{"text":"path, with no registry round-trip.","type":"text"}]},{"inlineContent":[{"type":"text","text":"Keep your "},{"type":"reference","identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType\/id","isActive":true},{"text":" strings stable across releases — they’re","type":"text"},{"type":"text","text":" "},{"text":"persisted on every port that references them.","type":"text"}],"type":"paragraph"},{"anchor":"Define-the-type","type":"heading","level":2,"text":"Define the type"},{"type":"codeListing","syntax":"swift","code":["import NodeKit","","extension PortType {","    static let color = PortType(","        id: \"myapp.color\",","        localizedDisplayName: \"Color\",","        color: .init(red: 0.95, green: 0.40, blue: 0.55)","    )","}","","let portTypes = PortTypeRegistry()","portTypes.register(.color)"]},{"inlineContent":[{"text":"The optional ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/ColorComponents"},{"text":" is a display hint — it colours the port","type":"text"},{"text":" ","type":"text"},{"text":"circle in the editor.","type":"text"}],"type":"paragraph"},{"anchor":"Reference-the-type-from-a-template","type":"heading","level":2,"text":"Reference the type from a template"},{"inlineContent":[{"text":"Ports take a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/NodeTemplate\/Port\/typeIdentifier"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let template = NodeTemplate(","    kind: .init(id: UUID(), localizedDisplayName: \"Tinter\"),","    inputs: [","        .init(id: UUID(), kind: .input,","              typeIdentifier: PortType.color.id,","              localizedDisplayName: \"Tint\")","    ],","    outputs: []",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For convenience there’s an overload that takes a "},{"type":"reference","identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortType","isActive":true},{"type":"text","text":" value"},{"type":"text","text":" "},{"type":"text","text":"directly — same effect, fewer keystrokes when the type is in scope:"}]},{"type":"codeListing","syntax":"swift","code":[".init(id: UUID(), kind: .input, type: .color, localizedDisplayName: \"Tint\")"]},{"type":"heading","text":"Register an inline editor","anchor":"Register-an-inline-editor","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Inline editors run when the user adds a literal value to an input port (the"},{"type":"text","text":" "},{"type":"codeVoice","code":"+"},{"type":"text","text":" button next to a port label). They get a strong-typed "},{"type":"codeVoice","code":"Binding<V>"},{"type":"text","text":"; the"},{"type":"text","text":" "},{"type":"text","text":"registry handles encoding to and from "},{"type":"reference","identifier":"doc:\/\/NodeKit\/documentation\/NodeKit\/PortValue\/custom(typeIdentifier:data:)","isActive":true},{"type":"text","text":" "},{"type":"text","text":"through "},{"type":"codeVoice","code":"JSONEncoder"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"JSONDecoder"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":"swift","code":["struct ColorValue: Codable, Sendable, Equatable {","    var red: Double, green: Double, blue: Double","}","","let editors = PortEditorRegistry()","editors.register(","    for: PortType.color.id,","    defaultValue: ColorValue(red: 1, green: 1, blue: 1)",") { binding in","    ColorPicker(","        \"\",","        selection: Binding(","            get: { Color(red: binding.wrappedValue.red,","                         green: binding.wrappedValue.green,","                         blue:  binding.wrappedValue.blue) },","            set: { _ in \/* decompose Color back into RGB *\/ }","        )","    )","    .labelsHidden()","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The same "},{"type":"codeVoice","code":"defaultValue"},{"type":"text","text":" is used as the fallback when stored data fails to"},{"type":"text","text":" "},{"type":"text","tex