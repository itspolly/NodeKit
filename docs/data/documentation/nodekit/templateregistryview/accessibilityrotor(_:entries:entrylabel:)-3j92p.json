 by ","type":"text"},{"code":"TemplateRegistry","type":"codeVoice"},{"text":". Pages are rendered","type":"text"},{"type":"text","text":" "},{"text":"as discrete sections in a ","type":"text"},{"code":"LazyVStack","type":"codeVoice"},{"type":"text","text":"; each section publishes its visibility"},{"type":"text","text":" "},{"text":"via ","type":"text"},{"code":".onAppear","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":".onDisappear","type":"codeVoice"},{"type":"text","text":", and the view keeps the registry’s loaded"},{"text":" ","type":"text"},{"type":"text","text":"window pinned to whichever pages are currently on screen. Scrolling beyond"},{"text":" ","type":"text"},{"type":"text","text":"the loaded edge reveals a placeholder section with a "},{"code":"ProgressView","type":"codeVoice"},{"type":"text","text":" while"},{"text":" ","type":"text"},{"text":"the next page streams in; scrolling back up evicts what’s no longer visible","type":"text"},{"text":" ","type":"text"},{"text":"and re-loads from the top with the same indicator.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TemplateRegistryView","kind":"identifier"}],"navigatorTitle":[{"text":"TemplateRegistryView","kind":"identifier"}],"url":"\/documentation\/nodekit\/templateregistryview","title":"TemplateRegistryView"}}}